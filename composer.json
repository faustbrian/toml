{
    "name": "cline/toml",
    "description": "A PHP parser for TOML compatible with specification 0.4.0",
    "license": "MIT",
    "keywords": [
        "toml",
        "parser",
        "configuration"
    ],
    "authors": [
        {
            "name": "Brian Faust",
            "email": "brian@cline.sh"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "yosymfony/parser-utils": "^2.0"
    },
    "require-dev": {
        "cline/coding-standard": "^1.5.6",
        "phpstan/phpstan": "^2.1"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Cline\\Toml\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest --parallel",
        "test:unit": "pest --parallel"
    }
}
